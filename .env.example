# =============================================================================
# BLACKLINE FITNESS — Environment variables template
# Copy this file to .env.local (git-ignored) and fill in the real values.
#
# .env.local is loaded automatically by Next.js in development.
# In production (Railway) set these as encrypted environment variables.
#
# NEVER commit .env.local or any file containing real secrets to git.
# =============================================================================


# ── Node ──────────────────────────────────────────────────────────────────────

NODE_ENV=development


# ── App ───────────────────────────────────────────────────────────────────────

# Public URL of the app (no trailing slash).
APP_URL=http://localhost:3000


# ── Database — PostgreSQL via Railway ──────────────────────────────────────────
#
# DATABASE_URL   : pooled connection (used by the app at runtime via PgBouncer).
# DIRECT_URL     : direct connection (used by Prisma migrate and Studio).
#
# Both are provided by Railway in the "PostgreSQL" plugin variables.

DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME?pgbouncer=true&connection_limit=10
DIRECT_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME


# ── Auth — NextAuth v5 ─────────────────────────────────────────────────────────
#
# NEXTAUTH_SECRET: random string >= 32 chars.
# Generate with: openssl rand -base64 32

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-me-with-a-random-string-at-least-32-chars


# ── SUPER_ADMIN bootstrap ──────────────────────────────────────────────────────
#
# Consumed by:
#   pnpm db:seed:super-admin     — promotes an existing user to SUPER_ADMIN
#                                   (requires SUPER_ADMIN_EMAIL only)
#   pnpm db:create-super-admin   — creates the user AND promotes in one step
#                                   (requires EMAIL + PASSWORD + optional NAME)
#
# SECURITY: unset these variables in production AFTER running the seed once.
# Keeping the plaintext password in env vars is a long-term liability — rotate
# it via the app UI as soon as the first SUPER_ADMIN can sign in.
#
# Minimum password length enforced by the script: 12 chars.

SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=Super Admin


# ── Email — Gmail SMTP (via nodemailer) ────────────────────────────────────────
#
# Active email transport. Uses Gmail SMTP with App Password authentication.
# Steps to set up:
#   1. Enable 2-Step Verification on the GMAIL_USER account:
#      https://myaccount.google.com/security
#   2. Generate an App Password (16 chars, no spaces):
#      https://myaccount.google.com/apppasswords
#   3. Set the values below.
#
# Limits: Gmail free ~500 emails/day, Workspace ~2000/day.
# Works with any Gmail or Google Workspace address (e.g. you@yourdomain.com).

GMAIL_USER=gerencia@jcanalytic.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
GMAIL_FROM_NAME=Blackline Fitness

# ── Email — Resend (legacy, kept for backward compat — not actively used) ──────
# Only relevant if you switch the transport back to Resend in lib/email/client.ts.

RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RESEND_FROM_EMAIL=noreply@blacklinefitness.app


# ── AI — Google Gemini ─────────────────────────────────────────────────────────
#
# Get an API key at https://aistudio.google.com/app/apikey

GEMINI_API_KEY=AIzaSy_REPLACE_WITH_REAL_KEY
GEMINI_MODEL_OCR=gemini-2.0-flash-lite
GEMINI_MODEL_REASONING=gemini-2.0-flash


# ── Storage — Cloudflare R2 ────────────────────────────────────────────────────
#
# R2_ACCOUNT_ID     : found in the Cloudflare dashboard URL bar (32-char hex)
# R2_ACCESS_KEY_ID  : R2 API token → Access Key ID
# R2_SECRET_ACCESS_KEY : R2 API token → Secret Access Key
# R2_BUCKET_PHOTOS  : bucket name for client progress photos
# R2_BUCKET_DOCUMENTS : bucket name for PDFs, signed certs, etc.
# R2_PUBLIC_URL     : public custom domain for the photos bucket (e.g. https://media.blacklinefitness.app)
# R2_ENDPOINT       : S3-compatible endpoint (https://ACCOUNT_ID.r2.cloudflarestorage.com)

R2_ACCOUNT_ID=0000000000000000000000000000000000
R2_ACCESS_KEY_ID=replace-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-r2-secret-access-key
R2_BUCKET_PHOTOS=blackline-fitness-photos
R2_BUCKET_DOCUMENTS=blackline-fitness-documents
R2_PUBLIC_URL=https://media.blacklinefitness.app
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com


# ── Payments — Tilopay ─────────────────────────────────────────────────────────
#
# Tilopay is the Costa Rican payment processor.
# TILOPAY_WEBHOOK_SECRET is used to verify HMAC signatures on incoming webhooks.

TILOPAY_API_KEY=replace-tilopay-api-key
TILOPAY_WEBHOOK_SECRET=replace-tilopay-webhook-secret


# ── Hacienda (Costa Rica e-invoicing — Comprobantes Electrónicos v4.4) ─────────
#
# Required only when BILLING_LIVE=true.
# HACIENDA_CERT_PATH : path to the PKCS#12 (.p12) certificate file on the server.
# HACIENDA_CERT_PIN  : PIN for the P12 certificate.

HACIENDA_USERNAME=cpj-0-000-000000@stag.comprobanteselectronicos.go.cr
HACIENDA_PASSWORD=replace-hacienda-password
HACIENDA_CERT_PATH=/run/secrets/hacienda.p12
HACIENDA_CERT_PIN=replace-cert-pin


# ── Observability ──────────────────────────────────────────────────────────────
#
# All three are optional — the app runs without them (pino logs to stdout).
# SENTRY_DSN : project DSN from https://sentry.io
# POSTHOG_KEY / POSTHOG_HOST : analytics from https://posthog.com

SENTRY_DSN=https://PUBLIC_KEY@ORGANIZATION.ingest.sentry.io/PROJECT_ID
POSTHOG_KEY=phc_REPLACE_WITH_REAL_KEY
POSTHOG_HOST=https://app.posthog.com


# ── Encryption — AES-256-GCM ──────────────────────────────────────────────────
#
# ENCRYPTION_KEY_PRIMARY   : required. 32-byte random key, base64-encoded.
#   Generate: openssl rand -base64 32
#
# ENCRYPTION_KEY_SECONDARY : optional. Used ONLY during key rotation:
#   1. Set SECONDARY = current PRIMARY
#   2. Set PRIMARY = new key
#   3. Run rotation job to re-encrypt all ciphertexts
#   4. Clear SECONDARY
#
# WARNING: losing the primary key means losing all encrypted data (cedulas, etc.)
# Store in a password manager AND in Railway's encrypted env vars.

ENCRYPTION_KEY_PRIMARY=REPLACE_WITH_OUTPUT_OF_openssl_rand_-base64_32
# ENCRYPTION_KEY_SECONDARY=only-set-during-key-rotation


# ── Feature flags ──────────────────────────────────────────────────────────────
#
# All boolean: set to "true" or "1" to enable; anything else (or absent) = false.
# AI_ASSIST_LIVE defaults to true so the AI UI renders in development.

PAYMENT_PROVIDER_LIVE=false
BILLING_LIVE=false
AI_ASSIST_LIVE=true
MEDIAPIPE_POSTURE_BETA=false
